ENV_PROFILE=production_trial
DATABASE_URL=sqlite:///./teamtask_agent.db
TEAMTASK_CONFIDENCE_THRESHOLD=0.6
TASK_EXTRACTOR_BACKEND=rule
TASK_EXTRACTOR_LLM_FALLBACK=true
LLM_TASK_API_BASE=https://api.openai.com/v1
LLM_TASK_API_KEY=
LLM_TASK_MODEL=
LLM_TASK_PROMPT_PATH=prompts/extract_tasks.md
LLM_TASK_RESPONSE_FORMAT=json_object
LLM_TASK_TIMEOUT_SECONDS=30
LLM_TASK_MAX_INPUT_CHARS=20000
LLM_TASK_TEMPERATURE=0

FEISHU_MOCK=false
LARK_DRY_RUN=false
LARK_CLI_DRY_RUN=false
FEISHU_SEND_DRY_RUN=false
BITABLE_DRY_RUN=false
TODO_PROJECTION_DRY_RUN=false
FEISHU_ENABLE_REAL_READ=true
TODO_BACKEND=bitable
MINUTES_BACKEND=lark_cli
RESOURCE_SEARCH_BACKEND=lark_cli

FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_VERIFICATION_TOKEN=
FEISHU_CARD_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=
FEISHU_CARD_ENCRYPT_KEY=
FEISHU_EVENT_ENCRYPTED=false
PUBLIC_BASE_URL=

LARK_CLI_PATH=lark-cli
MINUTES_DRY_RUN=false
RESOURCE_SEARCH_REAL_READ=true
RESOURCE_SEARCH_DRY_RUN=false

FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_TABLE_ID=
FEISHU_BITABLE_VIEW_ID=

FEISHU_MINUTES_SCOPE_REQUIRED=minutes:read
FEISHU_DOCS_SCOPE_REQUIRED=docs:read
FEISHU_DRIVE_SCOPE_REQUIRED=drive:read
FEISHU_BASE_SCOPE_REQUIRED=base:read

ALLOWED_USER_IDS=u_demo_initiator,u_demo_assignee
ALLOWED_CHAT_IDS=oc_demo_chat
ENABLE_REAL_WRITE_FOR_ALLOWED_USERS_ONLY=true
ENABLE_REAL_READ_FOR_ALLOWED_USERS_ONLY=true
